# React + Next.js + Monaco Editor setup
PORT=3000
NODE_ENV=development
JWT_SECRET=<generate-random-secret>
OPENAI_API_KEY=sk-your-openai-key-here
AI_PROVIDER=openai

# Coinbase WDK (for wallet creation)
COINBASE_API_KEY_NAME=your-coinbase-api-key-name
COINBASE_PRIVATE_KEY=your-coinbase-private-key

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/codemind
REDIS_URL=redis://localhost:6379

# Execution
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-key
